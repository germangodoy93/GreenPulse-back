# ─────────────────────────────────────────────────────────────────────────────
# GreenPulse API — Environment variables
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al control de versiones.
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=GreenPulse API
APP_VERSION=0.1.0
# Valores: development | staging | production
ENVIRONMENT=development
DEBUG=true

# ── Servidor ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Base de datos ─────────────────────────────────────────────────────────────
# Formato requerido: postgresql+asyncpg://usuario:password@host:puerto/nombre_bd
# Ejemplo local:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/greenpulse
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Seguridad / JWT ───────────────────────────────────────────────────────────
# Genera una clave segura con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_64
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista JSON de orígenes permitidos. En producción, solo el dominio del frontend.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
